{
    "name": "rent-flow",
    "version": "1.0.0",
    "type": "module",
    "description": "Renter management and billing application",
    "main": "./out/main/index.js",
    "author": "Antigravity",
    "scripts": {
        "format": "prettier --write .",
        "lint": "eslint . --ext .js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
        "start": "electron-vite preview",
        "dev": "electron-vite dev",
        "build": "electron-vite build",
        "postinstall": "electron-builder install-app-deps",
        "build:unpack": "bun run build && electron-builder --dir",
        "build:win": "bun run build && electron-builder --win",
        "build:mac": "bun run build && electron-builder --mac",
        "build:linux": "bun run build && electron-builder --linux"
    },
    "dependencies": {
        "@lucide/lab": "^0.1.2",
        "better-sqlite3": "^11.5.0",
        "clsx": "^2.1.1",
        "electron-log": "^5.2.0",
        "electron-updater": "^6.1.7",
        "jspdf": "^2.5.1",
        "jspdf-autotable": "^3.8.2",
        "lucide-react": "^0.378.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-router-dom": "^6.23.1",
        "recharts": "^2.12.7",
        "tailwind-merge": "^2.3.0"
    },
    "devDependencies": {
        "@electron-toolkit/eslint-config": "^1.0.2",
        "@electron-toolkit/eslint-config-prettier": "^1.0.1",
        "@electron-toolkit/preload": "^3.0.1",
        "@electron-toolkit/utils": "^3.0.0",
        "@vitejs/plugin-react": "^4.3.1",
        "autoprefixer": "^10.4.19",
        "electron": "^31.0.2",
        "electron-builder": "^24.13.3",
        "electron-vite": "^2.3.0",
        "eslint": "^8.57.0",
        "eslint-plugin-react": "^7.34.1",
        "postcss": "^8.4.38",
        "prettier": "^3.2.5",
        "tailwindcss": "^3.4.3",
        "vite": "^5.2.12"
    },
    "build": {
        "appId": "com.mollaneer.rentflow",
        "productName": "মোল্লা নীড়",
        "directories": {
            "output": "dist",
            "buildResources": "resources"
        },
        "files": [
            "out/**/*"
        ],
        "extraResources": [
            {
                "from": "resources",
                "to": "resources",
                "filter": [
                    "**/*"
                ]
            }
        ],
        "win": {
            "icon": "resources/icon.ico",
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ]
        },
        "mac": {
            "icon": "resources/icon.icns",
            "target": [
                "dmg"
            ]
        },
        "linux": {
            "icon": "resources/icon.png",
            "target": [
                "AppImage"
            ]
        }
    }
}